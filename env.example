# ============================================================
# Cash Flow — Environment Configuration
# Copy this file to .env and fill in your values.
# ============================================================

# ---- LLM (required for natural-language input & Telegram bot) ----

# Gemini API key (free tier: 20 req/day per key)
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Multiple keys for rate-limit rotation (optional)
# GEMINI_API_KEY_1=
# GEMINI_API_KEY_2=
# GEMINI_API_KEY_3=
# GEMINI_API_KEY_4=

# LLM provider/model overrides (optional, configured in llm_config.yaml by default)
# LLM_DEFAULT_PROVIDER=gemini
# LLM_DEFAULT_MODEL=gemini-2.5-flash
# LLM_OLLAMA_BASE_URL=http://localhost:11434

# Per-function model overrides (format: provider/model)
# LLM_PRE_PARSE_MODEL=ollama/llama3.2:3b
# LLM_TRANSACTION_PARSE_MODEL=gemini/gemini-2.5-flash
# LLM_SUBSCRIPTION_PARSE_MODEL=gemini/gemini-2.5-flash
# LLM_ACCOUNT_PARSE_MODEL=gemini/gemini-2.5-flash

# ---- Telegram Bot ----

# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram user IDs allowed to use the bot.
# Leave empty for open access (not recommended).
# Find your ID: message @userinfobot on Telegram.
TELEGRAM_ALLOWED_USERS=

# Auto-confirm behavior: skip the preview+confirm step.
#   extra_users_only — (default) extra users auto-save, owner gets preview
#   all              — everyone auto-saves
#   none             — everyone gets preview + confirm/revise
TELEGRAM_AUTO_CONFIRM=extra_users_only

# Bot language: "en" (English, default) or "es" (Spanish).
# Users can override at runtime with /lang.
TELEGRAM_DEFAULT_LANG=en

# Extra users (delegates): family members who log transactions through the bot.
# Their transactions are auto-saved and flagged for owner review.
# Format: TELEGRAM_EXTRA_USER_<NAME>=telegram_user_id,default_account,default_budget_name
# TELEGRAM_EXTRA_USER_MOM=987654321,Visa Pichincha,Home Groceries
# TELEGRAM_EXTRA_USER_DAD=123456789,Cash,Personal

# ---- Backup ----

# BACKUP_ENABLED=true              # Enable auto-backup before mutations (true/false)
# BACKUP_DIR=backups               # Directory for backup files
# BACKUP_KEEP_TODAY=5              # Max backups to keep from today
# BACKUP_RECENT_DAYS=7             # Keep one backup per day for this many recent days
# BACKUP_MAX_DAYS=30               # Delete backups older than this
# BACKUP_LOG_RETENTION_DAYS=30     # Delete backup log entries older than this
